{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:OPENCODE_MODEL}",
  "small_model": "{env:OPENCODE_SMALL_MODEL}",
  "server": {
    "hostname": "0.0.0.0",
    "port": 4096
  },
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  },
  "tools": {
    "write": true,
    "bash": true
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      ".next/**"
    ]
  }
}
